---
/**
 * Layout.astro — SEO-ready base layout
 * - Dynamic canonical with trailing slash
 * - Per-page OG/Twitter image + type
 * - Robots override per page
 * - Head slot for page-specific JSON-LD
 */
const {
  title = "SMBCyberHub",
  description = "SMB cybersecurity compliance kits. GDPR-aligned training, policies & checklists. Audit-ready in 60 minutes. No logins, no subscriptions.",
  ogImage = "https://smbcyberhub.com/images/smbcyberhub-logo.webp",
  ogType = "website",                // e.g. "website" (default) or "article" on posts
  robots = "index,follow",           // allow per-page override, e.g. "noindex,follow"
  canonical,                         // optional explicit canonical URL
  publishedTime,                     // ISO date string for article:published_time (blog posts)
  modifiedTime,                      // ISO date string for article:modified_time (blog posts)
  tags = []                          // string[] for article:tag OG meta (blog posts)
} = Astro.props;

const pathWithSlash = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalHref = canonical ?? `https://smbcyberhub.com${pathWithSlash}`;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "SMBCyberHub",
  "url": "https://smbcyberhub.com",
  "logo": {
    "@type": "ImageObject",
    "url": "https://smbcyberhub.com/images/smbcyberhub-logo.webp",
    "width": 224,
    "height": 112
  },
  "description": "Expert-led, downloadable cybersecurity compliance kits for small businesses. Privacy-first, No-SaaS approach with 60-minute implementation.",
  "knowsAbout": [
    "Cybersecurity Compliance",
    "NIST Cybersecurity Framework",
    "GDPR Compliance",
    "Cyber Insurance Readiness",
    "ISO/IEC 27001",
    "Small Business Security",
    "Privacy-First Security",
    "No-SaaS Solutions"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "email": "info@smbcyberhub.com",
    "availableLanguage": ["English"]
  },
  "founder": {
    "@type": "Person",
    "name": "Jim SMBCyberHub",
    "jobTitle": "Cybersecurity Compliance Specialist"
  },
  "sameAs": [
    "https://www.linkedin.com/in/smb-cyberhub-67567b374/",
    "https://x.com/SMBCyberHub"
  ]
};
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <link rel="alternate" type="application/rss+xml" title="SMB CyberHub Blog Feed" href="https://smbcyberhub.com/rss.xml" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalHref} />

    <!-- Preload LCP hero image -->
    <link rel="preload" as="image" href="/images/smbcyberhub-logo.webp" type="image/webp" />

    <!-- Preconnect to analytics and payment domains -->
    <link rel="preconnect" href="https://cloud.umami.is" />
    <link rel="dns-prefetch" href="https://smbcyberhub.gumroad.com" />

    <!-- Icons -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / Social -->
    <meta property="og:site_name" content="SMBCyberHub" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:locale" content="en_IE" />
    <meta property="og:locale:alternate" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@SMBCyberHub" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Article-specific OG meta (blog posts only) -->
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === 'article' && tags.length > 0 && tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={canonicalHref} />
    <link rel="alternate" hreflang="x-default" href={canonicalHref} />

    
    <!-- Site-wide Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>

    <!-- Page-level schema slot (pages can inject JSON-LD into <head>) -->
    <slot name="schema" />

    <!-- Privacy-friendly analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="fa515cb9-555e-45c1-92d5-7dee474ca120"></script>
  </head>

  <body class="min-h-screen flex flex-col bg-white text-gray-900 font-sans">
    <!-- Header Banner (blue background, logo + nav) -->
    <header class="w-full bg-[#234488] px-6 py-4">
      <div class="flex items-center justify-between">
        <a href="/" class="flex items-center">
          <img src="/images/smbcyberhub-logo.webp" alt="SMBCyberHub - Cybersecurity Compliance Kits for Small Business" class="h-28 w-auto" width="224" height="112" fetchpriority="high" />
          <span class="sr-only">SMBCyberHub Home</span>
        </a>
        <!-- Desktop nav -->
        <nav aria-label="Main Navigation" class="hidden lg:flex flex-wrap items-center gap-4 xl:gap-6 ml-4 xl:ml-6">
          <a href="/2026-compliance-checklist/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">2026 Checklist</a>
          <a href="/what-is-smb-cybersecurity-compliance/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">Compliance Guide</a>
          <a href="/kits/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">Compare Kits</a>
          <a href="/cyber-insurance-renewal-checklist/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">Insurance Checklist</a>
          <a href="/philosophy/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">Our Philosophy</a>
          <a href="/saas-vs-downloadable/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">SaaS vs Downloadable</a>
          <a href="/free-cyber-security-training/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">Free Training</a>
          <a href="/faq/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">FAQ</a>
          <a href="/about/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">About</a>
          <a href="/blog/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">Blog</a>
          <a href="/contact/" class="text-white font-medium hover:text-emerald-300 transition text-sm whitespace-nowrap">Contact</a>
        </nav>
        <!-- Mobile hamburger button -->
        <button id="mobile-menu-btn" class="lg:hidden text-white p-2" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      <!-- Mobile nav drawer -->
      <nav id="mobile-menu" class="hidden lg:hidden mt-4 pb-2" aria-label="Mobile Navigation">
        <div class="flex flex-col gap-3">
          <a href="/kits/" class="text-white font-semibold hover:text-emerald-300 transition text-base">Compare Kits</a>
          <a href="/free-cyber-security-training/" class="text-white font-semibold hover:text-emerald-300 transition text-base">Free Training</a>
          <a href="/2026-compliance-checklist/" class="text-white font-medium hover:text-emerald-300 transition text-sm">2026 Checklist</a>
          <a href="/cyber-insurance-renewal-checklist/" class="text-white font-medium hover:text-emerald-300 transition text-sm">Insurance Checklist</a>
          <a href="/what-is-smb-cybersecurity-compliance/" class="text-white font-medium hover:text-emerald-300 transition text-sm">Compliance Guide</a>
          <a href="/blog/" class="text-white font-medium hover:text-emerald-300 transition text-sm">Blog</a>
          <a href="/about/" class="text-white font-medium hover:text-emerald-300 transition text-sm">About</a>
          <a href="/faq/" class="text-white font-medium hover:text-emerald-300 transition text-sm">FAQ</a>
          <div class="flex flex-wrap gap-3 pt-2 border-t border-blue-400/30">
            <a href="/philosophy/" class="text-blue-200 hover:text-emerald-300 transition text-xs">Philosophy</a>
            <a href="/saas-vs-downloadable/" class="text-blue-200 hover:text-emerald-300 transition text-xs">SaaS vs Downloadable</a>
            <a href="/contact/" class="text-blue-200 hover:text-emerald-300 transition text-xs">Contact</a>
          </div>
        </div>
      </nav>
      <script>
        document.getElementById('mobile-menu-btn')?.addEventListener('click', function() {
          const menu = document.getElementById('mobile-menu');
          const expanded = this.getAttribute('aria-expanded') === 'true';
          this.setAttribute('aria-expanded', String(!expanded));
          menu?.classList.toggle('hidden');
        });
      </script>
    </header>

    <main class="flex-1 flex flex-col">
      <slot />
    </main>

    <footer class="w-full border-t border-gray-200 bg-gray-50 text-gray-600 text-sm py-8 px-6">
      <div class="max-w-6xl mx-auto">
        <!-- Multi-column footer links -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-6">
          <div>
            <h4 class="font-semibold text-gray-800 mb-2">Products</h4>
            <ul class="space-y-1">
              <li><a href="/kits/" class="hover:underline">Compare Kits</a></li>
              <li><a href="/basic-cybersecurity-kit/" class="hover:underline">Basic Kit</a></li>
              <li><a href="/pro-cybersecurity-kit/" class="hover:underline">Pro Kit</a></li>
              <li><a href="/free-cyber-security-training/" class="hover:underline">Free Sample</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-gray-800 mb-2">Resources</h4>
            <ul class="space-y-1">
              <li><a href="/blog/" class="hover:underline">Blog</a></li>
              <li><a href="/2026-compliance-checklist/" class="hover:underline">2026 Checklist</a></li>
              <li><a href="/cyber-insurance-renewal-checklist/" class="hover:underline">Insurance Checklist</a></li>
              <li><a href="/what-is-smb-cybersecurity-compliance/" class="hover:underline">Compliance Guide</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-gray-800 mb-2">Company</h4>
            <ul class="space-y-1">
              <li><a href="/about/" class="hover:underline">About</a></li>
              <li><a href="/philosophy/" class="hover:underline">Philosophy</a></li>
              <li><a href="/faq/" class="hover:underline">FAQ</a></li>
              <li><a href="/contact/" class="hover:underline">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-gray-800 mb-2">Legal</h4>
            <ul class="space-y-1">
              <li><a href="/terms/" class="hover:underline">Terms</a></li>
              <li><a href="/privacy/" class="hover:underline">Privacy</a></li>
              <li><a href="/licensing/" class="hover:underline">Licensing</a></li>
            </ul>
            <div class="mt-3 flex items-center gap-3">
              <a href="https://x.com/SMBCyberHub" target="_blank" rel="noopener noreferrer" class="hover:underline" aria-label="Follow SMBCyberHub on X">X</a>
              <a href="https://www.linkedin.com/in/smb-cyberhub-67567b374/" target="_blank" rel="noopener noreferrer" class="hover:underline" aria-label="Connect with SMBCyberHub on LinkedIn">LinkedIn</a>
            </div>
          </div>
        </div>
        <!-- Bottom bar -->
        <div class="border-t border-gray-200 pt-4 flex flex-col md:flex-row items-center justify-between gap-y-2">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 16v-4" />
              <path d="M12 8h.01" />
            </svg>
            GDPR Article 39.1(b) – No tracking or logins required.
          </div>
          <span>&copy; {new Date().getFullYear()} SMBCyberHub. All rights reserved.</span>
        </div>
      </div>
    </footer>
  </body>
</html>
