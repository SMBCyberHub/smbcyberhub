  url: 'https://smbcyberhub.com/best-cybersecurity-training-small-business/',
  author: {
    '@type': 'Person',
    name: 'Jim SMBCyberHub',
    jobTitle: 'Cybersecurity Compliance Specialist',
    url: 'https://smbcyberhub.com/about/'
  },
  publisher: {
    '@type': 'Organization',
    name: 'SMBCyberHub',
    url: 'https://smbcyberhub.com',
    logo: { '@type': 'ImageObject', url: 'https://smbcyberhub.com/images/smbcyberhub-logo.webp' }
  },
  datePublished: '2026-03-18',
  dateModified: '2026-03-18',
  image: ['https://smbcyberhub.com/images/smbcyberhub-logo.webp'],
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', 'section .bg-gradient-to-r p']
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: "What's the cheapest cybersecurity training for a small business?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: "SMBCyberHub offers the lowest total cost for small teams. The Pro Kit is a one-time payment of \u20AC99 with no per-user fees, no subscriptions, and no renewals. Wizer has a free tier with limited content, but full access starts at around $3/user/month. For a team of 10, that adds up to $360/year versus SMBCyberHub\u2019s one-time \u20AC99."
      }
    },
    {
      '@type': 'Question',
      name: 'Do I need enterprise tools like KnowBe4 for a small team?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For most small businesses with 1\u201320 staff, enterprise platforms like KnowBe4 or Proofpoint are overkill. They are designed for hundreds or thousands of users and come with per-seat pricing, onboarding overhead, and features most small teams will never use. A downloadable compliance kit or a lightweight platform like Wizer is usually a better fit.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is free cybersecurity training enough for compliance?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Free training can cover awareness basics, but most compliance frameworks (GDPR, ISO 27001, cyber insurance policies) require documented training records, formal policies, and audit-ready checklists. SMBCyberHub\u2019s paid kits include all of these. Free tools like Wizer\u2019s basic tier or SMBCyberHub\u2019s free sample are a good starting point but usually aren\u2019t sufficient on their own for a full audit."
      }
    },
    {
      '@type': 'Question',
      name: 'Can I run cybersecurity training offline without a SaaS platform?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Yes. SMBCyberHub kits are downloadable PDFs that work entirely offline. You can print them, run in-person training sessions, and keep all records on your own systems. This is ideal for teams that value privacy or operate in environments with limited internet access. Most SaaS platforms like KnowBe4, Wizer, and NINJIO require an active internet connection."
      }
    }
  ]
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://smbcyberhub.com/' },
    { '@type': 'ListItem', position: 2, name: 'Best Cybersecurity Training', item: 'https://smbcyberhub.com/best-cybersecurity-training-small-business/' }
  ]
