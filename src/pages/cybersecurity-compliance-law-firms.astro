---
import Layout from '../layouts/Layout.astro'

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Cybersecurity Compliance for Law Firms: A Practical Guide',
  description: 'How small law firms (1-20 staff) achieve cybersecurity compliance, protect attorney-client privilege, and satisfy SRA, ABA, and cyber insurance requirements.',
  url: 'https://smbcyberhub.com/cybersecurity-compliance-law-firms/',
  author: {
    '@type': 'Person',
    name: 'Jim SMBCyberHub',
    jobTitle: 'Cybersecurity Compliance Specialist',
    url: 'https://smbcyberhub.com/about/'
  },
