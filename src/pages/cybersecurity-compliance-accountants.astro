---
import Layout from '../layouts/Layout.astro'

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Cybersecurity Compliance for Accountants: Complete Guide for Small Firms',
  description: 'Cybersecurity compliance guide for accountants, CPAs, and tax preparers. Covers FTC Safeguards Rule, GDPR, cyber insurance, and staff training for firms with 1-20 employees.',
  url: 'https://smbcyberhub.com/cybersecurity-compliance-accountants/',
  author: {
    '@type': 'Person',
    name: 'Jim SMBCyberHub',
    jobTitle: 'Cybersecurity Compliance Specialist',
    url: 'https://smbcyberhub.com/about/'
  },
  publisher: {
    '@type': 'Organization',
    name: 'SMBCyberHub',
    url: 'https://smbcyberhub.com',
    logo: { '@type': 'ImageObject', url: 'https://smbcyberhub.com/images/smbcyberhub-logo.webp' }
  },
  datePublished: '2026-03-18',
  dateModified: '2026-03-18',
  image: ['https://smbcyberhub.com/images/smbcyberhub-logo.webp'],
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', 'section .bg-gradient-to-r p']
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does the SMBCyberHub kit cover FTC Safeguards Rule requirements?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The SMBCyberHub Pro Kit includes policy templates, staff training modules, risk assessment documentation, and incident response plans that map directly to FTC Safeguards Rule requirements for tax preparers and accountants.'
