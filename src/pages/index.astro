      "brand": {
        "@type": "Brand",
        "name": "SMBCyberHub"
      },
      "category": "Cybersecurity Compliance",
      "sameAs": "https://smbcyberhub.com/basic-cybersecurity-kit/",
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Compliance Framework",
          "value": "NIST CSF 2.0"
        },
        {
          "@type": "PropertyValue",
          "name": "GDPR Article 39",
          "value": "Staff Training Compliant"
        },
        {
          "@type": "PropertyValue",
          "name": "ISO/IEC 27001",
          "value": "Clause 7.2.2 Ready"
        },
        {
          "@type": "PropertyValue",
          "name": "Implementation Time",
          "value": "60 Minutes"
        }
      ],
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://smbcyberhub.gumroad.com/l/basickit",
        "priceValidUntil": priceValidUntil,
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "applicableCountry": "IE",
          "returnPolicyCategory": "NoReturns"
        },
        "shippingDetails": {
          "@type": "OfferShippingDetails",
          "shippingRate": {
            "@type": "MonetaryAmount",
            "value": "0.00",
            "currency": "EUR"
          },
          "shippingDestination": {
            "@type": "DefinedRegion",
            "addressCountry": "IE"
          },
          "deliveryTime": {
            "@type": "ShippingDeliveryTime",
            "handlingTime": {
              "@type": "QuantitativeValue",
              "minValue": 0,
              "maxValue": 0,
              "unitCode": "DAY"
            },
            "transitTime": {
              "@type": "QuantitativeValue",
              "minValue": 0,
              "maxValue": 0,
              "unitCode": "DAY"
            }
          }
        }
      }
    },
    {
      "@type": "Product",
      "name": "SMBCyberHub Pro Kit",
      "description": "Complete cybersecurity compliance toolkit with all 6 training modules, 6 staff quizzes, and a full compliance toolkit of policies, checklists, and audit documentation. Covers core topics plus advanced MFA, social engineering, and ransomware awareness.",
      "image": "https://smbcyberhub.com/images/smbcyberhub-logo.webp",
      "brand": {
        "@type": "Brand",
        "name": "SMBCyberHub"
      },
      "url": "https://smbcyberhub.gumroad.com/l/prokit",
      "sameAs": "https://smbcyberhub.com/pro-cybersecurity-kit/",
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Compliance Framework",
          "value": "NIST CSF 2.0"
        },
        {
          "@type": "PropertyValue",
          "name": "GDPR Article 39",
          "value": "Staff Training Compliant"
        },
        {
          "@type": "PropertyValue",
          "name": "ISO/IEC 27001",
          "value": "Clause 7.2.2 Ready"
        },
        {
          "@type": "PropertyValue",
          "name": "Implementation Time",
          "value": "60 Minutes"
        },
        {
          "@type": "PropertyValue",
          "name": "Advanced Modules",
          "value": "MFA, Social Engineering, Ransomware"
        }
      ],
      "offers": {
        "@type": "Offer",
        "price": "99",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://smbcyberhub.gumroad.com/l/prokit",
        "priceValidUntil": priceValidUntil,
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "applicableCountry": "IE",
          "returnPolicyCategory": "NoReturns"
        },
        "shippingDetails": {
          "@type": "OfferShippingDetails",
          "shippingRate": {
            "@type": "MonetaryAmount",
            "value": "0.00",
            "currency": "EUR"
          },
          "shippingDestination": {
            "@type": "DefinedRegion",
            "addressCountry": "IE"
          },
          "deliveryTime": {
            "@type": "ShippingDeliveryTime",
            "handlingTime": {
              "@type": "QuantitativeValue",
              "minValue": 0,
              "maxValue": 0,
              "unitCode": "DAY"
            },
            "transitTime": {
              "@type": "QuantitativeValue",
              "minValue": 0,
              "maxValue": 0,
              "unitCode": "DAY"
            }
          }
        }
      }
    },
    {
      "@type": "WebSite",
      "name": "SMBCyberHub",
      "url": "https://smbcyberhub.com",
      "description": "Privacy-first, downloadable cybersecurity compliance kits for small businesses. Audit-ready in 60 minutes. No logins, no subscriptions.",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".bg-blue-50 p", ".bg-emerald-50 p"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://smbcyberhub.com/"
        }
      ]
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need IT experience to use these kits?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No — all materials are designed for non-technical users. If you can onboard a new hire, you can run this training. Our Free Sample Kit shows exactly how simple it is."
      }
    },
    {
      "@type": "Question",
      "name": "Is it a subscription?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. All kits are a one-time download. No subscriptions, logins, or SaaS. You buy once and use forever."
      }
    },
    {
      "@type": "Question",
      "name": "Can I see a sample before buying?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — try the Free Sample Kit first, no signup required. It includes real training materials and tools from our Pro Kit."
      }
    }
  ]
};
---

<Layout 
  title="SMB Cybersecurity Compliance Kits | SMBCyberHub"
  description="SMB cybersecurity compliance kits — GDPR-aligned, NIST CSF-aligned training, policies, and checklists. Audit-ready in 60 minutes. No logins, no subscriptions."
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)}></script>
